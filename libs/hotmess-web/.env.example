# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration
VITE_APP_NAME=Hotmess Sports
VITE_APP_URL=http://localhost:4200

# Sports Engine Configuration
VITE_SPORTS_ENGINE_CLIENT_ID=your-client-id
VITE_SPORTS_ENGINE_REDIRECT_URI=http://localhost:4200/auth/callback

# Feature Flags (set to 'true' to enable mock mode for development)
VITE_USE_MOCK_AUTH=true
VITE_USE_MOCK_DATA=true
